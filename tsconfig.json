{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist-types",
    "lib": ["DOM", "ES2020", "WebWorker"]
  },
  "include": ["src/**/*", "extension/**/*"]
}
